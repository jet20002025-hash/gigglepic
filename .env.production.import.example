# Copy to `.env.production.import` (that file is gitignored) and paste values from
# Vercel → Project → Settings → Environment Variables (Production).
#
# Then from your Mac:
#   npm run import-images:prod
#
# This uploads everything in ./seed-images to R2 and inserts rows into Neon.

DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_BASE_URL=""
