# Neon（免费 Postgres）：https://neon.tech —— 复制连接串（建议加 sslmode=require）
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Auth.js / NextAuth —— 随机字符串即可：`openssl rand -base64 32`
AUTH_SECRET=""
# Google OAuth：https://console.cloud.google.com/apis/credentials → 创建「OAuth 客户端 ID」（Web）
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# 本地 http://localhost:3000 ；上线填 https://你的域名.vercel.app
AUTH_URL="http://localhost:3000"

# Cloudflare R2（对象存储）
# 在 Cloudflare 控制台创建 R2 Bucket → 创建 API Token（对象读写在包含该 Bucket）
# R2_ACCOUNT_ID：控制台右侧 Account ID
# R2_PUBLIC_BASE_URL：Bucket 启用公开访问后的域名，例如 https://pub-xxxx.r2.dev
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_BASE_URL=""

# Google AdSense（展示广告）— 在 https://www.google.com/adsense 开通后获取
# 客户端 ID，形如 ca-pub-xxxxxxxxxxxxxxxx（用于脚本 + ads.txt）
NEXT_PUBLIC_ADSENSE_CLIENT_ID=""
# 可选：在 AdSense 后台创建「广告单元」后填入 slot 编号（仅数字）。不配则只加载脚本（适合开启「自动广告」）
NEXT_PUBLIC_ADSENSE_SLOT_BELOW_IMAGE=""
NEXT_PUBLIC_ADSENSE_SLOT_ABOVE_FOOTER=""
