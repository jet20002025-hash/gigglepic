generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model FunnyImage {
  id         String    @id @default(cuid())
  storageKey String    @unique
  publicUrl  String
  mimeType   String?
  createdAt  DateTime  @default(now())
  comments   Comment[]
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  comments      Comment[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model Comment {
  id           String     @id @default(cuid())
  body         String     @db.VarChar(500)
  createdAt    DateTime   @default(now())
  userId       String
  funnyImageId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  funnyImage   FunnyImage @relation(fields: [funnyImageId], references: [id], onDelete: Cascade)

  @@index([funnyImageId])
}
